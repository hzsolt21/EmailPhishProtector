{
  "manifest_version": 3,
  "name": "Email Phish Protection",
  "version": "1.3",
  "description": "Protects against malicious links and forms in Gmail with trusted domain management",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "email-phish-protection@yourdomain.com",
      "strict_min_version": "109.0"
    }
  }
}
